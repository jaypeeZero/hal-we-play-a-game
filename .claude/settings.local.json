{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook rewrite",
            "type": "command"
          }
        ],
        "matcher": "Bash|bash"
      },
      {
        "hooks": [
          {
            "command": "lean-ctx hook redirect",
            "type": "command"
          }
        ],
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./test.sh:*)",
      "Bash(godot --headless --script addons/gut/gut_cmdln.gd -gdir=tests -gtest=test_damage_resolver.gd -gexit:*)",
      "Bash(godot --headless --script addons/gut/gut_cmdln.gd -gdir=tests -gtest=test_crew_ai_system.gd -gexit:*)",
      "WebSearch",
      "WebFetch(domain:en.wikipedia.org)",
      "Bash(grep:*)",
      "Bash(done)",
      "Bash(git log *)",
      "Bash(godot --headless --script addons/gut/gut_cmdln.gd -gdir=tests -gexit)"
    ],
    "ask": [],
    "deny": []
  }
}